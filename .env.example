# SimpleSave environment — copy to .env.local and fill in.
#
#   cp .env.example .env.local
#
# Single Next.js app. Auth is real Supabase Auth (GoTrue); data access is
# server-only via the Supabase anon key as the authenticated user, enforced by
# RLS. Never expose the service-role key to the browser.

# --- Supabase (Project Settings → API) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key — server/seed only (bypasses RLS). Required by `npm run seed`.
# NEVER ship this to the client. Keep it out of any NEXT_PUBLIC_* var.
SUPABASE_SERVICE_ROLE_KEY=

# Auth: Supabase Auth (GoTrue) signs/verifies JWTs server-side — no separate
# app-level AUTH_SECRET is required.

# --- Business rules (see DECISIONS.md) ---
PAYMENT_TO_INCOME_RATIO=0.40
MAX_AGE_NEW_MORTGAGE=85
MAX_AGE_REFINANCE=80

# --- Payments (deferred — checkout runs a Sandbox provider until these are set) ---
# Set these to wire a real PSP (e.g. Stripe) in place of the sandbox checkout.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
