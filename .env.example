# SimpleSave environment — copy to .env.local and fill in.
#
#   cp .env.example .env.local
#
# This is a single Next.js app (no Python). Data access is server-only via the
# Supabase anon key + a mock cookie session (demo auth). See lib/supabase.ts.

# Supabase project (dedicated to SimpleSave — never share with another product).
# Project Settings → API → Project URL / anon public key.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Business rules (see DECISIONS.md). Read by the headless API routes.
PAYMENT_TO_INCOME_RATIO=0.38
MAX_AGE_NEW_MORTGAGE=85
MAX_AGE_REFINANCE=80
