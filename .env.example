# SimpleSave environment — copy to .env and adjust.

# Direct Postgres connection for SQLAlchemy. For Supabase, use the pooler string from
# Project Settings → Database → Connection string (Transaction pooler):
#   postgresql+psycopg://postgres.<PROJECT_REF>:[YOUR-PASSWORD]@aws-0-<REGION>.pooler.supabase.com:6543/postgres
# Leave empty to fall back to a local SQLite file (development only).
DATABASE_URL=

# Supabase project (dedicated to SimpleSave — never share with another product).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Business rules (see DECISIONS.md).
PAYMENT_TO_INCOME_RATIO=0.38
MAX_AGE_NEW_MORTGAGE=85
MAX_AGE_REFINANCE=80
